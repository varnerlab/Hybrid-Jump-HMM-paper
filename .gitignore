# macOS
.DS_Store

# Claude Code local config (session-specific)
.claude/

# LaTeX build artifacts (the compiled PDF is tracked)
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.nav
*.snm
*.vrb
*.run.xml

# Julia coverage and track-allocation
*.jl.cov
*.jl.*.cov
*.jl.mem

# Julia BinaryProvider / BinDeps host-specific artifacts
deps/deps.jl
deps/build.log
deps/downloads/
deps/usr/
deps/src/

# Documenter.jl build artifacts
docs/build/
docs/site/

# Pkg Manifest (host-specific pinning; Project.toml is tracked)
Manifest*.toml

# Preferences.jl local files
LocalPreferences.toml
JuliaLocalPreferences.toml

# Pipeline outputs (regenerable from scripts; large binary artifacts)
code/data/*.jld2
code/data/*.csv
code/data/*.log
